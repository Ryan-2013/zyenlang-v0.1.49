import <std/test>;
import <std/list>;
import <std/string>;

fn add_pair(
    a: int,
    b: int
) -> int {
    return a + b;
}

fn join3(
    a: str,
    b: str,
    c: str
) -> str {
    return a + b + c;
}

struct Box {
    let this.items: List;

    fn add_many(
        a: str,
        b: str
    ) -> void {
        this.items.append(a);
        this.items.append(b);
    }

    fn size() -> int {
        return this.items.len();
    }
}

fn main() -> int {
    let t: TestStats = test.new_stats("multiline syntax");

    let n: int = add_pair(
        10,
        20
    );
    t.eq_int(
        "multiline function call",
        n,
        30
    );

    let text: str = join3(
        "Zy",
        "en",
        "Lang"
    );
    t.eq_str(
        "multiline string expression",
        text,
        "ZyenLang"
    );

    let xs: List = [
        "a",
        "b",
        "c"
    ];
    t.eq_int(
        "multiline list literal",
        xs.len(),
        3
    );

    if (
        string.eq(text, "ZyenLang")
    ) {
        t.check(
            "multiline if condition",
            true
        );
    } else {
        t.check(
            "multiline if condition",
            false
        );
    }

    let sum: int = 0;
    for (
        let i: int = 0;
        i < 4;
        i += 1
    ) {
        set sum += i;
    }
    t.eq_int(
        "multiline for header",
        sum,
        6
    );

    let b: Box = Box;
    b.add_many(
        "x",
        "y"
    );
    t.eq_int(
        "multiline method args",
        b.size(),
        2
    );

    return t.summary();
}
