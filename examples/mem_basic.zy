import <std/mem>;

fn main() -> int {
    let p: ptr<int> = mem.alloc_int(10);

    print(*p);

    set *p = 55;
    print(*p);

    print(mem.is_valid(p));
    print(mem.is_owned(p));
    print(mem.type_name(p));

    let code: int = mem.free(p);
    print(code);
    print(mem.is_valid(p));
    print(p);

    return 0;
}
