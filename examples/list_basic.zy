fn main() -> int {
    let list: List = List;

    list.append(1);
    list.append("hello");
    list.append(true);

    print(list);
    print(list.len());
    print(list.is_empty());
    print(list.get(0));
    print(list.get(1));
    print(list.get(2));

    list.set(0, 99);
    print(list.get(0));

    print(list.pop());
    print(list.len());

    list.clear();
    print(list.len());

    return 0;
}
