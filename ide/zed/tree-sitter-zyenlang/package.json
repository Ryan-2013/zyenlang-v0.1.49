{
  "name": "tree-sitter-zyenlang",
  "version": "0.1.10",
  "description": "Tree-sitter grammar for ZyenLang",
  "main": "grammar.js",
  "keywords": ["tree-sitter", "zyenlang"],
  "license": "MIT",
  "devDependencies": {
    "tree-sitter-cli": "^0.25.0"
  },
  "scripts": {
    "generate": "tree-sitter generate",
